{
  "name": "diepxuan/laravel-support",
  "description": "Support tools and utilities for Laravel development",
  "type": "composer-plugin",
  "license": "MIT",
  "authors": [
    {
      "name": "Tran Ngoc Duc",
      "email": "ductn@diepxuan.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "composer-plugin-api": "^2.0",
    "diepxuan/php-charset": "*",
    "diepxuan/laravel-core": "*"
  },
  "require-dev": {
    "composer/composer": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Diepxuan\\Support\\": "src/"
    }
  },
  "extra": {
    "class": "Diepxuan\\Support\\Composer\\DockerfileSqlsrvPlugin",
    "laravel": {
      "providers": [
        "Diepxuan\\Support\\SupportServiceProvider"
      ]
    }
  }
}
