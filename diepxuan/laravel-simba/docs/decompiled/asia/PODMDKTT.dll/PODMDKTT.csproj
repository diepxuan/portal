  </ItemGroup>
  <ItemGroup>
    <Reference Include="Microsoft.VisualBasic" />
    <Reference Include="Framework">
      <HintPath>../../../../projects/SimbaSql/native-apps/ASIA/Framework.dll</HintPath>
    </Reference>
  </ItemGroup>
</Project>