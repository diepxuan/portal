  <data name="TSQL_AllObj" xml:space="preserve"><value>SELECT CAST(0 AS BIT) AS chon,
       NAME,
       1 AS [Type],
       'View' AS TypeOfObject,
       create_date,
       modify_date AS Last_Modify,
       DB_NAME() + '\View\' + NAME AS fullPath
FROM   sys.views
UNION ALL
SELECT CAST(0 AS BIT) AS chon,
       NAME,
       1 AS [Type],
       'Stored Procedure' AS TypeOfObject,
       create_date,
       modify_date AS Last_Modify,
       DB_NAME() + '\Stored Procedure\' + NAME AS fullPath
FROM   sys.procedures
UNION ALL
SELECT CAST(0 AS BIT) AS chon,
       NAME,
       1 AS [Type],
       'Function' AS TypeOfObject,
       create_date,
       modify_date AS Last_Modify,
       DB_NAME() + '\Function\' + NAME AS fullPath
FROM   sys.objects
WHERE  type_desc LIKE '%FUNCTION%'
ORDER BY
       fullPath,
       Last_modify</value></data>
